{
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "family": "react-cicd-json-task",
    "containerDefinitions": [
        {
            "name": "react-cicd-json-container",
            "image": "521495323881.dkr.ecr.us-east-2.amazonaws.com/my-react-repo:latest",
            "portMappings": [
                {
                    "name": "ngnix-80-tcp",
                    "containerPort": 80,
                    "hostPort": 80,
                    "protocol": "tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": true
        }
    ],
    "volumes": [],
    "networkMode": "awsvpc",
    "memory": "512",
    "cpu": "256",
    "executionRoleArn": "arn:aws:iam::521495323881:role/ecsTaskExecutionRole"
}